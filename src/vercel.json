{
  "cleanUrls": true,
  "redirects": [
    {
      "source": "/.well-known/:path*",
      "destination": "https://lotterieservice.de/:path*",
      "permanent": true,
      "has": [
        {
          "type": "host",
          "value": "app.lotterieservice.de"
        }
      ]
    }
  ],
  "rewrites": []
}